rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: name, email, role (ADMIN, OPERADOR, BROKER, SUPER_ADMIN), teamId, active, permissions
    //
    // Collection: properties
    // Fields: title, location, price, type, status, image, description, features, gallery
    //
    // Collection: inventory_items
    // Fields: name, category, unit, minStock, currentStock, averageCost, imageUrl, usageStatus
    //
    // Collection: inventory_movements
    // Fields: itemId, type, quantity, unitPrice, totalPrice, date, destination, description, supplierId
    //
    // Collection: warehouses
    // Fields: name, location
    //
    // Collection: suppliers
    // Fields: name, cnpj, category, phone
    //
    // Collection: purchase_quotes
    // Fields: supplierId, supplierName, items, totalAmount, status, date, notes
    //
    // Collection: leads
    // Fields: name, email, phone, propertyId, propertyName, brokerId, status, date
    //
    // Collection: teams
    // Fields: name, description
    //
    // Collection: auctions
    // Fields: title, description, link, date, status, initialPrice, currentBid, myMaxBid, propertyType, city, neighborhood, auctioneer, bids
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['ADMIN', 'SUPER_ADMIN'] ||
        (request.auth.token.email == "miqueiasyout@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isOperator() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'OPERADOR';
    }

    function isBroker() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'BROKER';
    }

    function hasPermission(module, action) {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.permissions[module].hasAny([action]) || user.role in ['ADMIN', 'SUPER_ADMIN'];
    }

    // ===============================================================
    // Domain Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow update: if isAuthenticated() && (isAdmin() || isOwner(userId));
      allow delete: if isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /quotes/{quoteId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || isOperator() || resource.data.brokerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /auctions/{auctionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /logs/{logId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOperator();
    }

    match /brokers/{brokerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
