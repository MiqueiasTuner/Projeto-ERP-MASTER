rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (required, 'ADMIN' | 'OPERADOR')
    //   - teamId: string (optional)
    //   - organizationId: string (optional)
    //   - active: boolean (required)
    //   - permissions: map (required)
    //
    // Collection: teams
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //
    // Collection: properties
    // Document ID: auto-generated
    // ... (other collections follow similar patterns)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (getUserData().role == 'SUPER_ADMIN' ||
         (request.auth.token.email == "miqueiasyout@gmail.com" && request.auth.token.email_verified == true));
    }

    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'Administrador' || isSuperAdmin());
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && (getUserData().organizationId == orgId || isSuperAdmin());
    }

    function canAccessDoc(docData) {
      return isAuthenticated() && (isSuperAdmin() || docData.organizationId == getUserData().organizationId);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || getUserData().organizationId == orgId);
      allow write: if isAuthenticated() && isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isSuperAdmin() || getUserData().organizationId == resource.data.organizationId);
      allow create: if isAuthenticated() && (isAdmin() || isSuperAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin() || isSuperAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // Generic rule for all SaaS collections
    match /{collectionName}/{docId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || 
        !('organizationId' in getUserData()) || // Legacy users (no orgId) can see everything
        (resource != null && resource.data.organizationId == getUserData().organizationId) ||
        (resource == null) 
      );
      allow write: if isAuthenticated() && (
        isSuperAdmin() || 
        !('organizationId' in getUserData()) || // Legacy users can write (will be saved as 'default' or legacy)
        (resource == null && request.resource.data.organizationId == getUserData().organizationId) ||
        (resource != null && resource.data.organizationId == getUserData().organizationId && request.resource.data.organizationId == resource.data.organizationId)
      );
    }

    match /registration_requests/{requestId} {
      allow create: if true; // Allow anyone to request registration
      allow read, write: if isSuperAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
