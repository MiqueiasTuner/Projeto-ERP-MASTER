{
  "entities": {
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "An item in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "currentStock": { "type": "number" },
        "averageCost": { "type": "number" },
        "imageUrl": { "type": "string" },
        "usageStatus": { "type": "number" }
      },
      "required": ["name", "category", "unit"]
    },
    "InventoryMovement": {
      "title": "Inventory Movement",
      "description": "A stock movement (entry or exit)",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["ENTRADA_COMPRA", "SAIDA_OBRA"] },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "destination": { "type": "string" },
        "description": { "type": "string" },
        "supplierId": { "type": "string" }
      },
      "required": ["itemId", "type", "quantity", "date"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "A warehouse location",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["name", "location"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier of inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "category": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "PurchaseQuote": {
      "title": "Purchase Quote",
      "description": "A quote for purchasing inventory items",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["SOLICITADO", "COTACAO", "APROVADO", "RECEBIDO"] },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["supplierId", "status", "date"]
    },
    "Property": {
      "title": "Property",
      "description": "A real estate property",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "gallery": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "location", "price"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer lead",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "propertyId": { "type": "string" },
        "propertyName": { "type": "string" },
        "brokerId": { "type": "string" },
        "status": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "propertyId"]
    },
    "User": {
      "title": "User",
      "description": "An application user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERADOR"] },
        "teamId": { "type": "string" },
        "active": { "type": "boolean" },
        "permissions": { "type": "object" }
      },
      "required": ["name", "email", "role"]
    },
    "Team": {
      "title": "Team",
      "description": "An organizational team or department",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Auction": {
      "title": "Auction",
      "description": "A real estate auction",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "link": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ABERTO", "ARREMATADO", "PERDIDO", "FINALIZADO"] },
        "initialPrice": { "type": "number" },
        "currentBid": { "type": "number" },
        "myMaxBid": { "type": "number" },
        "propertyType": { "type": "string" },
        "city": { "type": "string" },
        "neighborhood": { "type": "string" },
        "auctioneer": { "type": "string" },
        "bids": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["title", "date", "status", "initialPrice"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A property expense",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["propertyId", "category", "amount", "date"]
    },
    "Log": {
      "title": "Log",
      "description": "A property activity log",
      "type": "object",
      "properties": {
        "propertyId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["propertyId", "action", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "A project task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string" }
      },
      "required": ["title", "status"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A system alert",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["title", "message", "type", "date"]
    },
    "Broker": {
      "title": "Broker",
      "description": "A real estate broker",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "creci": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "email"]
    }
  },
  "firestore": {
    "/inventory": { "schema": "InventoryItem", "description": "Collection of inventory items" },
    "/movements": { "schema": "InventoryMovement", "description": "Collection of stock movements" },
    "/warehouses": { "schema": "Warehouse", "description": "Collection of warehouses" },
    "/suppliers": { "schema": "Supplier", "description": "Collection of suppliers" },
    "/quotes": { "schema": "PurchaseQuote", "description": "Collection of purchase quotes" },
    "/properties": { "schema": "Property", "description": "Collection of properties" },
    "/leads": { "schema": "Lead", "description": "Collection of leads" },
    "/users": { "schema": "User", "description": "Collection of users" },
    "/teams": { "schema": "Team", "description": "Collection of teams" },
    "/auctions": { "schema": "Auction", "description": "Collection of auctions" },
    "/expenses": { "schema": "Expense", "description": "Collection of expenses" },
    "/logs": { "schema": "Log", "description": "Collection of logs" },
    "/tasks": { "schema": "Task", "description": "Collection of tasks" },
    "/alerts": { "schema": "Alert", "description": "Collection of alerts" },
    "/brokers": { "schema": "Broker", "description": "Collection of brokers" }
  }
}
